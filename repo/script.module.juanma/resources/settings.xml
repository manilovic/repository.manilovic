<?xml version="1.0" encoding="UTF-8"?>
<settings>
	<category label="Opciones">
		<setting id="config_hash" type="string" default="" visible="false"/>
		<setting id="debug" type="bool" label="Habilitar Mensajes Debug" default="true"/>
		<setting id="canales_on" type="bool" label="Solo canales validos" default="true"/>
		<setting id="stop_acestream" type="bool" label="Parar Acestream automaticamente" default="true" visible="!System.Platform.Android" option="close"/>
		<setting id="clear_cache_acestream" label="Limpiar caché Acestream" type="action"  action="RunPlugin(plugin://script.module.juanma?limpiar_cache_setting)" visible="!System.Platform.Android" option="close"/>
		<setting id="stop_acestream_2" label="Parada Forzosa Acestream AHORA" type="action"  action="RunPlugin(plugin://script.module.juanma?parar_acestream_2)"  visible="!System.Platform.Android" option="close"/>
		<setting label="Horus install acestream" type="action"  action="RunPlugin(plugin://script.module.horus?action=install_acestream)" visible="!System.Platform.Android" option="close"/>
	</category>
</settings>
